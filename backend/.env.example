# ─── Deepgram (transcrição + diarização Nova-2) ──────────────────────────────
# Criar chave em https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=efcaf...

# ─── OpenAI (sumarização GPT-4o) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── CORS extra (separado por vírgula) ───────────────────────────────────────
EXTRA_ALLOWED_ORIGINS=

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# No Cloud Run: usa Application Default Credentials (ADC) do service account
# Em dev local: configurar path para o JSON do service account
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase_key.json
