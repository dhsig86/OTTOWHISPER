# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── CORS extra (separado por vírgula) ───────────────────────────────────────
EXTRA_ALLOWED_ORIGINS=

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# No Cloud Run: configurar via Secret Manager ou variável de ambiente
# Nunca colocar o JSON da chave no repositório
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase_key.json

# ─── HuggingFace (pyannote — diarização) ─────────────────────────────────────
# Criar token em https://huggingface.co/settings/tokens
# Aceitar termos em https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=hf_...
